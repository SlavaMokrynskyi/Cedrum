{
  "name": "web-wallet",
  "version": "0.2.0",
  "private": true,
  "dependencies": {
    "@cedra-labs/ts-sdk": "^2.2.8",
    "@chakra-ui/react": "^2.1.2",
    "@emotion/react": "^11",
    "@emotion/styled": "^11",
    "@scure/bip39": "^2.0.1",
    "@tanstack/react-query": "^5.90.21",
    "@types/react-dom": "^18.0.2",
    "axios": "^1.13.5",
    "buffer": "^6.0.3",
    "constate": "^3.3.2",
    "qr-code-styling": "^1.9.2",
    "react": "^18.0.0",
    "react-cookie": "^8.0.1",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.3.0"
  },
  "scripts": {
    "start": "vite",
    "lint": "tsc --noEmit",
    "lint:fix": "tsc --noEmit",
    "tauri": "tauri",
    "prebuild": "rimraf build public/build",
    "build": "npm run lint:fix && npm run build:app && npm run build:sidebar && npm run build:scripts",
    "build:tauri": "npm run tauri -- build --target aarch64-apple-darwin",
    "build:app": "vite build",
    "build:sidebar": "webpack --config webpack.sidepanel.config.js",
    "build:bg": "webpack --config webpack.scripts.config.js --entry ./src/scripts/background.js --output-filename background.js",
    "build:inpage": "webpack --config webpack.scripts.config.js --entry ./src/scripts/inpage.js --output-filename inpage.js",
    "build:scripts": "webpack --config webpack.scripts.config.js",
    "test": "echo \"No test runner configured\""
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@tauri-apps/cli": "^1.0.0-rc.13",
    "@types/chrome": "^0.1.37",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.11",
    "@types/react": "^18.0.6",
    "@vitejs/plugin-react": "^5.1.4",
    "assert": "^2.0.0",
    "css-loader": "^7.1.4",
    "https-browserify": "^1.0.0",
    "os-browserify": "^0.3.0",
    "process": "^0.11.10",
    "rimraf": "^6.1.2",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.3.0",
    "tsconfig-paths-webpack-plugin": "^3.5.2",
    "typescript": "^4.6.3",
    "url": "^0.11.0",
    "vite": "^7.3.1",
    "webpack": "^5.105.2",
    "webpack-cli": "^4.9.2"
  }
}
