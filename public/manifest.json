{
  "short_name": "Cedrum",
  "name": "Cedrum Wallet",
  "version": "1.0.0",
  "manifest_version": 3,

  "action": {
    "default_popup": "index.html"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentscript.js"],
      "run_at": "document_start"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["inpage.js"],
      "matches": ["<all_urls>"]
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "permissions": ["storage", "sidePanel", "tabs"],

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "windows": "Alt+Shift+1",
        "mac": "Alt+Shift+1",
        "chromeos": "Alt+Shift+1",
        "linux": "Alt+Shift+1"
      }
    }
  },

  "icons": {
    "128": "icon.png",
    "16": "icon.png",
    "48": "icon.png"
  }
}
